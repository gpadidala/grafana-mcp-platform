# ─────────────────────────────────────────────────────────────────
# Grafana MCP Platform — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=                        # TODO: Grafana service account token
GRAFANA_ORG_ID=1

# ── MCP Server ────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8080/sse

# ── LLM Providers ─────────────────────────────────────────────────
# OpenAI
OPENAI_API_KEY=sk-...                   # TODO
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...            # TODO

# Azure OpenAI
AZURE_OPENAI_API_KEY=                   # TODO
AZURE_OPENAI_ENDPOINT=                  # TODO: https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=                # TODO: your deployment name

# Google Gemini
GOOGLE_API_KEY=                         # TODO

# Ollama (local LLM — only needed if using Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible (vLLM, LM Studio, LiteLLM proxy)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# ── LLM Defaults ─────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4o
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096
MAX_TOOL_ITERATIONS=10
ENABLE_STREAMING=true

# ── Auth ──────────────────────────────────────────────────────────
# For local dev: API key auth only (no JWT needed)
API_KEY_SECRET=change-me-local-dev-only

# For production OIDC/OAuth2 (JWT validation):
AUTH_JWKS_URI=                          # TODO: e.g., https://login.microsoftonline.com/.../.well-known/openid-configuration/jwks
AUTH_ISSUER=                            # TODO: e.g., https://sts.windows.net/your-tenant-id/

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# ── Cloud Provider ────────────────────────────────────────────────
# local | aws | azure | gcp
CLOUD_PROVIDER=local

# AWS Secrets Manager (EKS)
AWS_REGION=us-east-1
AWS_SECRET_PREFIX=grafana-mcp

# Azure Key Vault (AKS)
AZURE_KEYVAULT_URL=                     # TODO

# GCP Secret Manager (GKE)
GCP_PROJECT_ID=                         # TODO

# ── Frontend (Vite env vars) ──────────────────────────────────────
# These are build-time variables — set before npm run build
VITE_API_BASE_URL=/api
VITE_GRAFANA_URL=http://localhost:3000
VITE_API_KEY=change-me-local-dev-only   # Matches API_KEY_SECRET above
